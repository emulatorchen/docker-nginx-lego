# Required
CERTBOT_EMAIL=your@email.org

# Optional (Defaults)
DHPARAM_SIZE=2048
ELLIPTIC_CURVE=secp256r1
RENEWAL_INTERVAL=8d
RSA_KEY_SIZE=2048
STAGING=0
USE_ECDSA=1

# Advanced (Defaults)
# Set a default DNS provider for all certs without an explicit .dns-<provider> suffix.
# Example: LEGO_DEFAULT_PROVIDER=cloudflare
# CERTBOT_AUTHENTICATOR is accepted as a backward-compatible alias.
LEGO_DEFAULT_PROVIDER=
DEBUG=0
USE_LOCAL_CA=0
